# AI Daily Briefing - Environment Variables
# Copy this file to .env and fill in your actual values.

# Required: Exa API Key (https://exa.ai)
EXA_API_KEY=your_exa_api_key_here

# Required for Feishu delivery: Feishu App credentials (https://open.feishu.cn)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_HOME_CHANNEL=oc_your_chat_id

# Optional: GitHub Personal Access Token (increases API rate limit from 10 to 30 req/min)
GITHUB_TOKEN=your_github_token_optional
